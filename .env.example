# =============================================================================
# WaffleWeather Environment Configuration
#
# Copy this file to .env and fill in your values.
# All backend vars use the WW_ prefix (read by Pydantic Settings).
# =============================================================================

# --- Database ----------------------------------------------------------------
# Native installs: set the full connection URL.
# Docker installs: only WW_DB_PASSWORD is needed (compose builds the URL).
WW_DATABASE_URL=postgresql+asyncpg://waffleweather:changeme@localhost:5432/waffleweather
WW_DB_PASSWORD=changeme

# --- MQTT --------------------------------------------------------------------
# Native installs: WW_MQTT_BROKER defaults to localhost.
# Docker installs: compose overrides to the mosquitto container name.
WW_MQTT_BROKER=localhost
WW_MQTT_PORT=1883
WW_MQTT_TOPIC=Gateway
WW_MQTT_USERNAME=waffleweather
WW_MQTT_PASSWORD=changeme

# --- API ---------------------------------------------------------------------
WW_CORS_ORIGINS=["http://localhost:3000"]
WW_ENABLE_DOCS=false
WW_API_KEY=

# --- Lightning filter (WH57 ghost strike suppression) ------------------------
# WW_LIGHTNING_FILTER_ENABLED=true
# WW_LIGHTNING_FILTER_DISTANCES=[12.0, 14.0]
# WW_LIGHTNING_FILTER_MAX_STRIKES=1

# --- Station metadata --------------------------------------------------------
WW_STATION_NAME=My Weather Station
WW_STATION_LATITUDE=40.7128
WW_STATION_LONGITUDE=-74.0060
WW_STATION_ALTITUDE=10.0
