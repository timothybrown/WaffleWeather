# =============================================================================
# WaffleWeather Docker Environment
#
# Copy this file to .env in this directory:  cp .env.example .env
# Then edit .env and fill in your values.
# =============================================================================

# --- Passwords (required) ----------------------------------------------------
WW_DB_PASSWORD=changeme
WW_MQTT_PASSWORD=changeme

# --- MQTT --------------------------------------------------------------------
WW_MQTT_USERNAME=waffleweather
WW_MQTT_TOPIC=Gateway

# --- CORS (WebSocket origin allowlist) ---------------------------------------
# Default allows http://localhost. Add your hostname if accessing via LAN/Tailscale:
#   WW_CORS_ORIGINS=["http://localhost","http://myhost.local","https://myhost.ts.net"]
WW_CORS_ORIGINS=["http://localhost"]

# --- API ---------------------------------------------------------------------
# Leave empty for unauthenticated (fine for LAN-only). Set a key for public.
WW_API_KEY=

# --- Station metadata --------------------------------------------------------
WW_STATION_NAME=My Weather Station
WW_STATION_LATITUDE=40.7128
WW_STATION_LONGITUDE=-74.0060
WW_STATION_ALTITUDE=10.0
WW_STATION_TIMEZONE=America/New_York

# --- Lightning filter (WH57 ghost strike suppression) ------------------------
# WW_LIGHTNING_FILTER_ENABLED=true
# WW_LIGHTNING_FILTER_DISTANCES=[12.0, 14.0]
# WW_LIGHTNING_FILTER_MAX_STRIKES=1
